{
  "name": "@calledit/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "demo": "DEMO_MODE=true DATABASE_PATH=/tmp/calledit-demo.db npm run build && DEMO_MODE=true DATABASE_PATH=/tmp/calledit-demo.db node dist/scripts/demo.js",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@solana/web3.js": "^1.98.4",
    "dotenv": "^16.4.7",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
