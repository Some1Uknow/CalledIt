NODE_ENV=development
PORT=8787
DATABASE_PATH=./calledit.db
DEMO_MODE=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=CalledItBetBot
TELEGRAM_WEBHOOK_SECRET=
TXLINE_NETWORK=devnet
TXLINE_BASE_URL=https://txline-dev.txodds.com/api/
TXLINE_SERVICE_LEVEL=1
TXLINE_AUTH_JWT=
TXLINE_API_TOKEN=
TXLINE_COMPETITION_ID=
RECEIPT_CHAIN_ENABLED=false
SOLANA_RPC_URL=
SOLANA_RECEIPT_PROGRAM_ID=
SOLANA_RECEIPT_KEYPAIR_PATH=

# Devnet market (disabled until the market program/config PDA are deployed)
MARKET_ENABLED=false
PUBLIC_BASE_URL=
SOLANA_MARKET_PROGRAM_ID=
# JSON-encoded Solana keypair secret; set only in your secret manager.
SOLANA_MARKET_AUTHORITY_SECRET=
# Local devnet convenience only; production should use the secret above.
SOLANA_MARKET_AUTHORITY_KEYPAIR_PATH=
# Optional public key. If omitted, the market authority also acts as the
# finality signer; it is the only signer allowed to submit a TxLINE final proof.
SOLANA_MARKET_SETTLEMENT_AUTHORITY=
SOLANA_MARKET_EMERGENCY_AUTHORITY=
# Optional JSON-encoded emergency keypair. If omitted, the market authority
# key is used only when it matches SOLANA_MARKET_EMERGENCY_AUTHORITY.
SOLANA_MARKET_EMERGENCY_SECRET=
MARKET_STAKE_LAMPORTS=10000000
MARKET_MAX_ENTRIES=100
MARKET_INTENT_TTL_SECONDS=900
